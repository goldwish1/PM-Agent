# OpenAI 兼容网关（变量名沿用 DEEPSEEK_*）
# 本项目默认示例：NIO 网关 + DeepSeek-V4-Flash
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=DeepSeek-V4-Flash

# 也可改为其他 OpenAI 兼容端，例如官方 DeepSeek：
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# LLM 切换：
# - true  → 始终 FakeLLM（无需 Key）
# - false → 始终 Real（必须配置有效 DEEPSEEK_API_KEY）
# - 不设置 → 有有效 Key 用 Real，否则自动 Fake 并提示
# USE_FAKE_LLM=true

OUTPUT_DIR=./output
MAX_TOOL_ITERATIONS=10

# LLM 调试观测：
# - PMBOX_DEBUG：终端 [llm] 摘要（默认 off；设 1 开启）
# - PMBOX_DEBUG_DUMP：每用户回合落盘 output/debug/turn-NNN.json（默认 on；设 0 关闭）
# 会话内也可用 /debug、/dump 切换。
# PMBOX_DEBUG=1
# PMBOX_DEBUG_DUMP=0
